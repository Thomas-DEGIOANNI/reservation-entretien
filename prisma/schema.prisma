generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Reservation {
  id        Int      @id @default(autoincrement())

  start     DateTime
  end       DateTime

  type      String

  status    String   @default("disponible")

  nom       String?
  prenom    String?
  email     String?
  telephone String?

  createdAt DateTime @default(now())
}
model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}